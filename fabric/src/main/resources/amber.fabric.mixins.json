{
  "required": true,
  "minVersion": "0.8",
  "package": "com.iamkaf.amber.mixin",
  "refmap": "${mod_id}.refmap.json",
  "compatibilityLevel": "${mixin_compat_fabric}",
  "mixins": [
    //? if >=1.16
    "AnimalMixin",
    //? if <1.16
    "BreedGoalMixin",
    "BlockItemMixin",
    "BoneMealItemMixin",
    //? if >=1.20.5
    "BuiltInRegistriesMixin",
    "CraftedItemMixin",
    "CraftingPlayerMixin",
    "CropBlockMixin",
    "FarmlandBlockMixin",
    //? if >=1.20.5
    "ItemAccessor",
    "ItemEntityMixin",
    "LightningBoltMixin",
    "LivingEntityAfterDamageMixin",
    "PlayerMixin",
    "ServerPlayerDeathMixin",
    "ServerLevelMixin",
    "SheepMixin",
    "TamableAnimalMixin"
  ],
  "client": [
    "LevelRendererMixin",
    "MouseHandlerMixin"
  ],
  "server": [],
  "injectors": {
    "defaultRequire": 1
  }
}
  
